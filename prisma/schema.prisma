generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("user") // 'admin', 'user', 'manager'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         Project[]
  aiChatSessions   AiChatSession[]
  
  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  phase       String?
  progress    Float    @default(0)
  teamSize    Int      @default(1)
  priority    String   @default("medium") // 'low', 'medium', 'high', 'critical'
  status      String   @default("active") // 'active', 'on-hold', 'completed'
  githubUrl   String?
  startDate   DateTime @default(now())
  dueDate     DateTime?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiChatSessions AiChatSession[]
  memorySummary  ProjectMemorySummary?
  repoSnapshot   ProjectRepoSnapshot?
  decisions      ProjectDecision[]
  rules          ProjectRule[]
  tasks          ProjectTask[]
  files          ProjectFile[]

  @@map("projects")
}

model AiChatSession {
  id           String   @id @default(cuid())
  type         String   // 'general' or 'project'
  userId       String
  projectId    String?
  title        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project  Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages AiChatMessage[]

  @@map("ai_chat_sessions")
}

model AiChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String   // 'user' or 'assistant'
  content   String
  metadata  Json?    // Additional context metadata
  createdAt DateTime @default(now())

  session AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ai_chat_messages")
}

model ProjectMemorySummary {
  id          String   @id @default(cuid())
  projectId   String   @unique
  summary     String
  lastUpdated DateTime @default(now())
  version     Int      @default(1)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_memory_summaries")
}

model ProjectDecision {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String
  impact      String?
  madeAt      DateTime @default(now())
  madeBy      String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_decisions")
}

model ProjectRule {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String
  priority    String   @default("medium") // 'low', 'medium', 'high'
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_rules")
}

model ProjectTask {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      String   @default("todo")
  priority    String   @default("medium")
  phase       String   @default("development")
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_tasks")
}

model ProjectFile {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  type        String   @default("doc") // 'doc', 'image', 'spreadsheet', 'design', 'code', 'other'
  phase       String   @default("development") // 'product-modeling', 'development', 'marketing'
  url         String?
  size        String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_files")
}

model ProjectRepoSnapshot {
  id            String   @id @default(cuid())
  projectId     String   @unique
  githubUrl     String
  repoName      String
  defaultBranch String
  description   String   @default("")
  fileTree      String   @db.Text
  languages     String
  keyFiles      String   @db.Text
  lastSyncedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_repo_snapshots")
}
