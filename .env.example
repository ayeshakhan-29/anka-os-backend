# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/anka_os?schema=public"

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Encryption for sensitive data (GitHub tokens, etc.)
# Generate a secure 32-character key for production
ENCRYPTION_KEY=your_32_character_encryption_key_here_change_this_in_production

# CORS
FRONTEND_URL=http://localhost:3000
